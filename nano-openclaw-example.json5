{
  // ==========================================
  // nano-openclaw 配置示例
  // ==========================================
  // 使用方法：
  // 1. 复制此文件为 nano-openclaw.json5
  // 2. 修改下面的配置项（特别是 API key）
  // 3. 将配置文件放在以下任一位置：
  //    - 命令行指定：uv run python -m nano_openclaw --config nano-openclaw.json5
  //    - 环境变量：export OPENCLAW_CONFIG_PATH=./nano-openclaw.json5
  //    - 状态目录下：~/.openclaw/nano-openclaw.json5
  //    - workspace 目录下：{cwd}/workspace/nano-openclaw.json5
  //
  // 完整字段说明见：docs/CONFIG_EXAMPLE.md
  // ==========================================

  // Agent 配置
  agents: {
    // 全局默认值（所有 agent 共享）
    defaults: {
      // 主模型，格式：provider/model-id
      // 内置 provider（anthropic、openai）无需额外配置
      model: "anthropic/claude-sonnet-4-5-20250929",

      // 图像理解模型（用于图片描述）
      // null = 使用 Native Vision（图片直接发给主模型）
      // 设置后走 Media Understanding 路径（先用图片模型描述，再注入 prompt）
      imageModel: null,

      // Agent 工作目录（相对或绝对路径）
      workspace: "./workspace",

      // 默认思考等级（可选）
      // 可选值：off | minimal | low | medium | high | xhigh | adaptive | max
      // thinkingDefault: off,

      // Workspace 文件注入预算配置（可选）
      // 控制 AGENTS.md、SOUL.md 等文件注入到系统提示的大小限制
      // bootstrapMaxChars: 12000,    // 单个文件最大字符数（默认 12000）
      // bootstrapTotalMaxChars: 60000, // 所有文件总字符数（默认 60000）
    },

    // Agent 列表（用于多 agent 配置）
    list: [
      {
        id: "default",
        default: true,
        name: "Default Agent",
        // 可以覆盖 defaults 中的字段：
        // model: "openai/gpt-4o",
        // workspace: "./workspace-default",
      },
      // 多 agent 示例（取消注释启用）：
      // {
      //   id: "coder",
      //   name: "Coding Agent",
      //   model: "anthropic/claude-sonnet-4-5-20250929",
      //   workspace: "./workspace-coder",
      // },
      // {
      //   id: "analyst",
      //   name: "Analysis Agent",
      // },
    ],
  },

  // ==========================================
  // 模型/Provider 配置
  // ==========================================
  models: {
    // merge = 自定义 provider 合并到内置 provider（默认）
    // replace = 仅使用自定义 provider，忽略内置
    mode: "merge",

    // 自定义 Provider 定义
    providers: {
      // Provider ID（自定义，用于模型引用格式：your-provider/model-id）
      "your-provider": {
        // API 端点 URL（必需）
        baseUrl: "https://your-api-endpoint.com/v1",

        // API 密钥（支持环境变量替换语法）
        // 推荐：设置为环境变量后使用 "${YOUR_API_KEY}" 语法
        apiKey: "${YOUR_API_KEY}",

        // API 协议类型
        // 可选值：anthropic-messages | openai-completions | openai-responses
        api: "openai-completions",

        // 模型列表
        models: [
          {
            // 模型 ID（在 provider 内唯一，用于引用：your-provider/your-model）
            id: "your-model",

            // 显示名称（可选）
            name: "Your Custom Model",

            // 输入模态（可选，默认 ["text"]）
            // 可选值：text | image | video | audio
            input: ["text", "image"],

            // 是否支持推理（可选，默认 false）
            reasoning: false,

            // 同 thinkingDefault
            params: { thinking: "low" },

            // 上下文窗口大小（可选，默认 8192）
            contextWindow: 128000,

            // 最大输出 token 数（可选，默认 4096）
            maxTokens: 8192,
          },
        ],
      },

      // 多 Provider 示例（取消注释启用）：
      // "openrouter": {
      //   baseUrl: "https://openrouter.ai/api/v1",
      //   apiKey: "${OPENROUTER_API_KEY}",
      //   api: "openai-completions",
      //   models: [
      //     {
      //       id: "anthropic/claude-sonnet-4",
      //       name: "Claude Sonnet 4",
      //       input: ["text", "image"],
      //       contextWindow: 200000,
      //       maxTokens: 8192,
      //     },
      //   ],
      // },
    },
  },

  // ==========================================
  // Session 配置
  // ==========================================
  session: {
    // 空闲超时分钟数
    idleMinutes: 60,

    // 重置模式配置
    reset: {
      // daily = 每天重置，idle = 空闲后重置
      mode: "idle",

      // 空闲多少分钟后重置
      idleMinutes: 120,
    },
  },

  // ==========================================
  // nano-openclaw 自定义字段
  // ==========================================

  // 禁用工具，纯对话模式（默认 false）
  noTools: false,

  // 每轮用户输入最大工具调用次数（默认 12）
  maxIterations: 12,

  // 上下文压缩配置
  context: {
    // 上下文 token 预算（默认 100000）
    budget: 100000,

    // 触发压缩的阈值比例（默认 0.8 = 80%）
    threshold: 0.8,

    // 压缩时保留的最近对话轮数（默认 3）
    recent_turns: 3,
  },

  // ==========================================
  // Active Memory 配置（自动记忆召回）
  // ==========================================
  // 每次用户发送消息前，自动搜索 workspace/MEMORY.md 和 workspace/memory/*.md
  // 将相关记忆注入 system prompt，让 agent 自动记住你的偏好和历史。
  //
  // 取消注释并修改以启用：
  // activeMemory: {
  //   enabled: true,
  //
  //   // 子 agent 使用的模型（可指定快速小模型节省成本，默认复用主模型）
  //   // model: "anthropic/claude-haiku-4-5-20251001",
  //
  //   // 查询模式：message（仅最新消息）| recent（最近N轮）| full（完整历史）
  //   queryMode: "recent",
  //
  //   // 召回风格：balanced | strict | contextual | recall-heavy | precision-heavy | preference-only
  //   promptStyle: "balanced",
  //
  //   // 超时时间（毫秒，250-120000，默认 15000）
  //   timeoutMs: 15000,
  //
  //   // 返回摘要最大字符数（40-1000，默认 220）
  //   maxSummaryChars: 220,
  //
  //   // recent 模式：保留最近几条用户消息（0-4，默认 2）
  //   recentUserTurns: 2,
  //
  //   // recent 模式：保留最近几条 assistant 回复（0-3，默认 1）
  //   recentAssistantTurns: 1,
  //
  //   // recent 模式：每条用户消息的字符限制（40-1000，默认 220）
  //   recentUserChars: 220,
  //
  //   // recent 模式：每条 assistant 回复的字符限制（40-1000，默认 180）
  //   recentAssistantChars: 180,
  //
  //   // 结果缓存 TTL（毫秒，1000-120000，默认 15000）
  //   cacheTtlMs: 15000,
  //
  //   // 是否打印调试日志（默认 false）
  //   logging: false,
  // },

  // ==========================================
  // Dreaming 配置（后台记忆整合，默认关闭）
  // ==========================================
  // Dreaming 会追踪 memory_search 的召回记录，定期将高频、高质量的记忆
  // 自动提升到 MEMORY.md（长期记忆），并生成 DREAMS.md 日记。
  //
  // 取消注释并修改以启用：
  // dreaming: {
  //   enabled: true,
  //
  //   // 调度频率（cron 格式，默认每天凌晨 3 点）
  //   // 支持 "minute hour * * *" 格式，与 openclaw 保持一致
  //   frequency: "0 3 * * *",
  //
  //   // 提升门槛：综合评分（0.0-1.0，默认 0.5）
  //   minScore: 0.5,
  //
  //   // 提升门槛：最少召回次数（默认 2）
  //   minRecallCount: 2,
  //
  //   // 提升门槛：最少不同查询数（默认 1）
  //   minUniqueQueries: 1,
  //
  //   // 每次最多提升条目数（默认 10）
  //   maxPromotions: 10,
  //
  //   // 是否生成 Dream Diary 日记（需要额外 API 调用，默认 true）
  //   diary: true,
  //
  //   // Dream Diary 生成模型（null = 复用主模型）
  //   // model: "anthropic/claude-haiku-4-5-20251001",
  // },

  // ==========================================
  // MCP 配置（外部工具服务器，默认关闭）
  // ==========================================
  // MCP（Model Context Protocol）用于连接外部工具服务器。
  // 支持三种传输方式：stdio（本地进程）、SSE、streamable-http（远程服务器）。
  //
  // 取消注释并修改以启用：
  // mcp: {
  //   servers: {
  //     // stdio 传输：本地文件系统服务器
  //     "filesystem": {
  //       command: "npx",
  //       args: ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allowed/dir"],
  //       // env: { "DEBUG": "1" },
  //       // cwd: "/working/directory",
  //     },
  //     // SSE 传输：远程服务器
  //     // "remote-server": {
  //     //   url: "https://mcp.example.com/sse",
  //     //   transport: "sse",
  //     //   headers: { "Authorization": "Bearer ${MCP_API_KEY}" },
  //     // },
  //     // streamable-http 传输
  //     // "streamable-server": {
  //     //   url: "https://mcp.example.com/mcp",
  //     //   transport: "streamable-http",
  //     //   connectionTimeoutMs: 10000,
  //     // },
  //   },
  //   // 会话空闲超时（可选）
  //   // sessionIdleTtlMs: 300000,
  // },

}
